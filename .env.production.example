# =============================================================================
# Real Estate Platform – Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in all values marked REQUIRED.
# NEVER commit the actual .env.production file to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_APP_URL=https://your-domain.com         # REQUIRED: Public URL of the app
VITE_APP_ID=realestate-platform              # REQUIRED: App identifier
LOG_LEVEL=info

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=                                  # REQUIRED: Min 32-char random string
OAUTH_SERVER_URL=                            # REQUIRED: OAuth provider URL
OWNER_OPEN_ID=                               # REQUIRED: Admin user's OpenID

# ── PostgreSQL (Primary Database) ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/realestate  # REQUIRED
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                           # REQUIRED: Strong password
POSTGRES_DB=realestate

# ── PostGIS (Spatial Database) ────────────────────────────────────────────────
POSTGIS_HOST=localhost
POSTGIS_PORT=5432
POSTGIS_DATABASE=realestate_spatial
POSTGIS_USER=postgres
POSTGIS_PASSWORD=                            # REQUIRED: Same or separate DB password
POSTGIS_SSL=true
POSTGIS_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:PASSWORD@localhost:6379   # REQUIRED
REDIS_PASSWORD=                              # REQUIRED: Strong password

# ── Microservices Ports ───────────────────────────────────────────────────────
PAYMENT_SERVICE_PORT=8001
NOTIFICATION_SERVICE_PORT=8002
IMAGE_SERVICE_PORT=8003
ML_VALUATION_SERVICE_PORT=9001
OCR_SERVICE_PORT=9002
FRAUD_DETECTION_SERVICE_PORT=9003

# ── Microservices URLs (internal) ─────────────────────────────────────────────
PAYMENT_SERVICE_URL=http://payment-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8002
IMAGE_SERVICE_URL=http://image-service:8003
ML_VALUATION_SERVICE_URL=http://ml-valuation:9001
OCR_SERVICE_URL=http://ocr-service:9002
FRAUD_DETECTION_SERVICE_URL=http://fraud-detection:9003

# ── Database Connection Pool ──────────────────────────────────────────────────
DB_POOL_MAX=10                              # Max connections in pool (default: 10)
DB_POOL_IDLE_TIMEOUT=30000                  # Idle connection timeout ms (default: 30s)
DB_POOL_CONNECT_TIMEOUT=5000               # Connection timeout ms (default: 5s)
DB_SSL=false                                # Set to true for managed DB with SSL

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com  # REQUIRED

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...               # REQUIRED
STRIPE_WEBHOOK_SECRET=whsec_...            # REQUIRED
VITE_STRIPE_PUBLIC_KEY=pk_live_...         # REQUIRED

# ── Flutterwave / Paystack (Africa Payments) ──────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=                           # REQUIRED
FROM_EMAIL=noreply@your-domain.com

# ── SMTP (Fallback Email) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=                              # REQUIRED if using SMTP

# ── Twilio / WhatsApp ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── AWS / S3 / MinIO ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=realestate-platform-backups
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=                        # REQUIRED: Strong password
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=                                 # REQUIRED for error tracking
GRAFANA_PASSWORD=                           # REQUIRED: Strong password
GRAFANA_ADMIN_USER=admin

# ── ClickHouse (Analytics) ────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=                        # REQUIRED

# ── OpenSearch (Search) ───────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=                        # REQUIRED

# ── APISIX (API Gateway) ──────────────────────────────────────────────────────
APISIX_ADMIN_KEY=                           # REQUIRED: Min 32-char random string

# ── Keycloak (Identity) ───────────────────────────────────────────────────────
KEYCLOAK_URL=https://auth.your-domain.com   # REQUIRED: Keycloak base URL
KEYCLOAK_REALM=realestate                   # REQUIRED: Keycloak realm name
KEYCLOAK_CLIENT_ID=realestate-app           # REQUIRED: Keycloak client ID
KEYCLOAK_ADMIN_PASSWORD=                    # REQUIRED
KEYCLOAK_DB_PASSWORD=                       # REQUIRED

# ── Fluvio (Streaming) ────────────────────────────────────────────────────────
FLUVIO_ENDPOINT=http://fluvio-sc:9003       # Fluvio REST API endpoint (optional)
FLUVIO_API_KEY=                             # Fluvio API key (optional)

# ── Permify (Authorization) ───────────────────────────────────────────────────
PERMIFY_ENDPOINT=http://permify:3476        # Permify gRPC/HTTP endpoint (optional)
PERMIFY_API_KEY=                            # Permify API key (optional)
PERMIFY_TENANT_ID=t1                        # Permify tenant ID (default: t1)

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────
SENTRY_ENABLED=true                         # Set to true to enable Sentry
SENTRY_TRACES_SAMPLE_RATE=0.1              # 10% of transactions sampled
SENTRY_PROFILES_SAMPLE_RATE=0.1           # 10% of profiles sampled

# ── Wazuh (Security) ──────────────────────────────────────────────────────────
WAZUH_ADMIN_PASSWORD=                       # REQUIRED

# ── AI / ML Services ─────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
OPENAI_API_KEY=

# ── Blockchain / Hyperledger ──────────────────────────────────────────────────
FABRIC_ORG1_ADMIN_PW=
FABRIC_ORG2_ADMIN_PW=
# ── Innovation Features ───────────────────────────────────────────────────────
# Blockchain Notarization
INFURA_POLYGON_URL=                         # Infura Polygon RPC URL (optional — uses local Merkle if unset)
NOTARY_WALLET_PRIVATE_KEY=                  # Ethereum wallet private key for on-chain anchoring
NOTARY_CONTRACT_ADDRESS=                    # Deployed notarization smart contract address
# Federated Identity Wallet
PLATFORM_DID=did:key:zPlatformRealEstateNG  # Platform DID for issuing VCs
# Ollama (local LLM for AI features)
OLLAMA_BASE_URL=http://ollama:11434         # Ollama API base URL
OLLAMA_MODEL=llama3.2                       # Default Ollama model
# Database Pool
DB_POOL_MAX=10                              # Max DB connections (default: 10)
DB_POOL_IDLE_TIMEOUT=30000                  # Idle connection timeout ms (default: 30000)
DB_POOL_CONNECTION_TIMEOUT=10000            # Connection acquisition timeout ms (default: 10000)
# CORS
ALLOWED_ORIGINS=https://your-domain.com    # REQUIRED: Comma-separated allowed origins
# App URL (used in certificates and emails)
APP_URL=https://your-domain.com             # REQUIRED: Public app URL

# ── OSRM Self-Hosted Routing ──────────────────────────────────────────────────
# Local docker-compose: http://localhost:5010
# Kubernetes: http://osrm-proxy.osrm.svc.cluster.local
OSRM_URL=http://localhost:5010

# Zestimate ML Services Configuration
# Copy this to .env and fill in your API keys for external deployment

# ============================================
# Google Maps API (Required for CV & AltData services)
# ============================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable these APIs:
# - Maps Static API (for aerial imagery)
# - Street View Static API (for street view)
# - Places API (for POI data)
# - Geocoding API (for address lookups)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# OpenStreetMap Fallback (Optional)
# ============================================
# Set to 'true' to use OpenStreetMap instead of Google Maps for aerial imagery
# This is useful for development or if you want to avoid Google Maps costs
USE_OSM=false

# ============================================
# ML Service Ports (Default values)
# ============================================
GNN_SERVICE_PORT=5003
CV_SERVICE_PORT=5004
ALTDATA_SERVICE_PORT=5005
ENSEMBLE_SERVICE_PORT=5006
BIAS_SERVICE_PORT=5007

# ============================================
# ML Service URLs (for tRPC integration)
# ============================================
# These should point to where your Python services are running
# For local development, use localhost
# For production, use your deployed service URLs
GNN_SERVICE_URL=http://localhost:5003
CV_SERVICE_URL=http://localhost:5004
ALTDATA_SERVICE_URL=http://localhost:5005
ENSEMBLE_SERVICE_URL=http://localhost:5006
BIAS_SERVICE_URL=http://localhost:5007

# ============================================
# Redis (Optional - for caching)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ============================================
# Model Training Configuration
# ============================================
# Path to store trained models
MODEL_STORAGE_PATH=./models

# Training data source
TRAINING_DATA_PATH=./data/training

# Model update frequency (in hours)
MODEL_UPDATE_FREQUENCY=24

# ============================================
# Feature Flags
# ============================================
# Enable/disable specific ML features
ENABLE_GNN_VALUATION=true
ENABLE_CV_ASSESSMENT=true
ENABLE_ALTDATA_ENRICHMENT=true
ENABLE_ENSEMBLE_PREDICTION=true
ENABLE_BIAS_CORRECTION=true

# ============================================
# Logging & Monitoring
# ============================================
ML_SERVICE_LOG_LEVEL=INFO
ENABLE_ML_METRICS=true

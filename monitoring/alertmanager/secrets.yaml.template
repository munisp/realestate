# Alertmanager Secrets Template
# Copy to secrets.yaml and fill in actual values

apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-secrets
  namespace: monitoring
type: Opaque
stringData:
  slack-webhook-url: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
  sendgrid-api-key: "SG.your-sendgrid-api-key"
  pagerduty-service-key: "your-pagerduty-integration-key"

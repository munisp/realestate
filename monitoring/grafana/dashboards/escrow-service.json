{
  "dashboard": {
    "title": "Escrow Service Monitoring",
    "tags": ["payment", "escrow", "go"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "type": "graph",
        "title": "HTTP Request Rate",
        "targets": [
          {
            "expr": "rate(escrow_http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}} - {{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "type": "graph",
        "title": "HTTP Request Duration (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(escrow_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
        "type": "singlestat",
        "title": "Total Escrows Created",
        "targets": [
          {
            "expr": "escrow_created_total",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "current"
      },
      {
        "id": 4,
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
        "type": "singlestat",
        "title": "Total Escrows Released",
        "targets": [
          {
            "expr": "escrow_released_total",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "current"
      },
      {
        "id": 5,
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
        "type": "singlestat",
        "title": "Total Escrows Refunded",
        "targets": [
          {
            "expr": "escrow_refunded_total",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "current"
      },
      {
        "id": 6,
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
        "type": "singlestat",
        "title": "Error Rate",
        "targets": [
          {
            "expr": "rate(escrow_errors_total[5m])",
            "refId": "A"
          }
        ],
        "format": "ops",
        "valueName": "current",
        "thresholds": "0.1,1"
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "type": "graph",
        "title": "Escrows by Status",
        "targets": [
          {
            "expr": "escrow_by_status",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Count"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "type": "graph",
        "title": "Redis Operation Duration",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(escrow_redis_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "{{operation}} (p95)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(escrow_redis_operation_duration_seconds_bucket[5m]))",
            "legendFormat": "{{operation}} (p99)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 9,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "type": "graph",
        "title": "Events Logged by Type",
        "targets": [
          {
            "expr": "rate(escrow_events_logged_total[5m])",
            "legendFormat": "{{event_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Events/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "type": "graph",
        "title": "Error Rate by Type",
        "targets": [
          {
            "expr": "rate(escrow_errors_total[5m])",
            "legendFormat": "{{type}} - {{operation}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Errors/sec"},
          {"format": "short"}
        ]
      }
    ]
  }
}
